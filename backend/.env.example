# ! lembre-se de renomear esse arquivo para `.env`

# endereco do database (postgres:18)
# ==================================
# ATENCAO: mude as credenciais antes de rodar em producao
# credenciais
DB_USER=app_user
DB_PASSWORD=app_password
# formato: postgresql+psycopg://user:password@host:port/dbname
DATABASE_URL="postgresql+psycopg://${DB_USER}:${DB_PASSWORD}@localhost:5432/app_db"

# configuracoes pyjwt
# ===================
# ATENCAO: gere uma chave com o seguinte comando (usando uv):
# `uv run python -c "import secrets; print(secrets.token_hex(32))"`
SECRET_KEY="substitua-por-uma-chave-gerada-pelo-comando-acima"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
